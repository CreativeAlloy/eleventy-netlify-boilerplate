<head>
  <meta charset="utf-8">
  <meta name='impact-site-verification' value='1c8a5e65-0378-4c83-aec5-229e75d3544b'>
  <meta name="generator" content="{{ eleventy.generator }}">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <title>{{ title or metadata.title }}</title>

  {# Standard SEO #}
  <meta name="description" content="{{ summary or metadata.description }}">

  {# Open Graph / Discord Embeds #}
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{ title or metadata.title }}">
  <meta property="og:description" content="{{ summary or metadata.description }}">
  <meta property="og:url" content="{{ metadata.url }}{{ page.url }}">
  <meta property="og:site_name" content="{{ metadata.title }}">

  {# --- IMAGE EMBED LOGIC --- #}
  {% set firstImagePath %}{% get_first_image layoutContent %}{% endset %}
  
  {% if firstImagePath %}
    {# metadata.url has no trailing slash, so this joins perfectly #}
    {% set absoluteImageUrl %}{{ metadata.url }}{{ firstImagePath }}{% endset %}
    <meta property="og:image" content="{{ absoluteImageUrl }}">
    <meta name="twitter:card" content="summary_large_image">
  {% endif %}
  {# ------------------------- #}

  {% set css %}
    {% include "assets/css/inline.css" %}
  {% endset %}
  <style>{{ css | cssmin | safe }}</style>

  {# Uncomment below if you want to include minified inline JavaScript #}
  {# {% set js %}
    {% include "assets/js/inline.js" %}
  {% endset %}
  <script>{{ js | jsmin | safe }}</script> #}
</head>
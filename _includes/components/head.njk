<head>
  <meta charset="utf-8">
  <meta name='impact-site-verification' value='1c8a5e65-0378-4c83-aec5-229e75d3544b'>
  <meta name="generator" content="{{ eleventy.generator }}">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  {# Improved Title Branding #}
  <title>{% if title %}{{ title }} | {{ metadata.title }}{% else %}{{ metadata.title }}{% endif %}</title>

  {# Canonical URL to prevent duplicate content issues #}
  <link rel="canonical" href="{{ metadata.url }}{{ page.url }}">

  {# Standard SEO #}
  <meta name="description" content="{{ summary or metadata.description }}">
  <meta name="author" content="{{ author or metadata.author.name }}">

  {# Open Graph / Discord Embeds #}
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{ title or metadata.title }}">
  <meta property="og:description" content="{{ summary or metadata.description }}">
  <meta property="og:url" content="{{ metadata.url }}{{ page.url }}">
  <meta property="og:site_name" content="{{ metadata.title }}">

  {# --- IMAGE EMBED LOGIC --- #}
  {% set firstImagePath %}{% get_first_image layoutContent %}{% endset %}
  
  {% if firstImagePath %}
    {% set absoluteImageUrl %}{{ metadata.url }}{{ firstImagePath }}{% endset %}
    <meta property="og:image" content="{{ absoluteImageUrl }}">
    <meta name="twitter:card" content="summary_large_image">
  {% else %}
    {# Fallback image if no image is found in the post #}
    <meta property="og:image" content="{{ metadata.url }}/static/img/default-embed-preview.png">
    <meta name="twitter:card" content="summary">
  {% endif %}

  {# Twitter Specifics (Used by many scrapers) #}
  <meta name="twitter:title" content="{{ title or metadata.title }}">
  <meta name="twitter:description" content="{{ summary or metadata.description }}">

  {# Structured Data (JSON-LD) - This is high-level SEO for "Serious" journalism #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title or metadata.title }}",
    "description": "{{ summary or metadata.description }}",
    "author": {
      "@type": "Person",
      "name": "{{ author or metadata.author.name }}"
    },
    "datePublished": "{{ page.date | dateToRfc3339 }}",
    "publisher": {
      "@type": "Organization",
      "name": "{{ metadata.title }}"
    }
  }
  </script>

  {% set css %}
    {% include "assets/css/inline.css" %}
  {% endset %}
  <style>{{ css | cssmin | safe }}</style>
</head>
<!doctype html>
<html {% if section %} data-current="{{ section }}"{% endif %} lang="en">

	{% include "components/head.njk" %}

	<body class="{% if serious or '/tags/serious/' in page.url %}serious-theme{% elif lecture or '/tags/lecture/' in page.url %}lecture-theme{% endif %}">

		<header>
			<div class="content-wrapper" style="position: relative;"> 
				
				{# The Fancy Toggle #}
				<div class="theme-switch-wrapper">
					<em>Dark Mode</em>
					<label class="theme-switch" for="dark-mode-toggle">
						<input type="checkbox" id="dark-mode-toggle">
						<div class="slider"></div>
					</label>
				</div>

				<em>
					<a href="{{ '/' | url }}">{{ metadata.title }}</a>
				</em>
				{% include "components/nav.njk" %}
				{% include "components/a-ads.njk" %}
			</div>
		</header>

		<main>
			{{ layoutContent | safe }}
		</main>

		{# The existing footer has text-align: center, which might be enough.
		   If its content still looks off, we can wrap its inner content
		   with <div class="content-wrapper"> too. Let's see first. #}
		{% include "components/footer.njk" %}

		<script src='https://storage.ko-fi.com/cdn/scripts/overlay-widget.js'></script>
		<script>
		const toggle = document.querySelector('#dark-mode-toggle');
		const body = document.body;
		const savedTheme = localStorage.getItem('theme');

		// 1. Initial State Setting
		if (savedTheme === 'dark') {
			body.classList.add('dark-mode');
			toggle.checked = true;
		}

		// 2. Centralized Ko-fi Render Function
		function drawKofi() {
			const themeVar = body.classList.contains('serious-theme') ? '--primary-serious' : 
							body.classList.contains('lecture-theme') ? '--primary-lecture' : '--primary';
			const activeColor = window.getComputedStyle(body).getPropertyValue(themeVar).trim();

			// Safely wipe any existing Ko-fi elements to prevent duplicates
			document.querySelectorAll('.floatingchat-container-wrap, iframe[id^="kofi-wo-window"]').forEach(el => el.remove());

			// Redraw the widget with the exact active color
			kofiWidgetOverlay.draw('creativealloy', {
			'type': 'floating-chat',
			'floating-chat.donateButton.text': 'Tip Me',
			'floating-chat.donateButton.background-color': activeColor || '#2e6319', 
			'floating-chat.donateButton.text-color': '#fff'
			});
		}

		// 3. Draw on Page Load
		drawKofi();

		// 4. Handle Theme Switch
		toggle.addEventListener('change', () => {
			if (toggle.checked) {
			body.classList.add('dark-mode');
			localStorage.setItem('theme', 'dark');
			} else {
			body.classList.remove('dark-mode');
			localStorage.setItem('theme', 'light');
			}
			
			// Redraw button immediately after the CSS variables update
			setTimeout(drawKofi, 50);
		});
		</script>

	</body>

</html>
<!doctype html>
<html {% if section %} data-current="{{ section }}"{% endif %} lang="en">

	{% include "components/head.njk" %}

	<body class="{% if serious or '/tags/serious/' in page.url %}serious-theme{% elif lecture or '/tags/lecture/' in page.url %}lecture-theme{% endif %}">

		<header>
			<div class="content-wrapper" style="position: relative;"> 
				
				{# The Fancy Toggle #}
				<div class="theme-switch-wrapper">
					<em>Dark Mode</em>
					<label class="theme-switch" for="dark-mode-toggle">
						<input type="checkbox" id="dark-mode-toggle">
						<div class="slider"></div>
					</label>
				</div>

				<em>
					<a href="{{ '/' | url }}">{{ metadata.title }}</a>
				</em>
				{% include "components/nav.njk" %}
				{% include "components/a-ads.njk" %}
			</div>
		</header>

		<main>
			{{ layoutContent | safe }}
		</main>

		{# The existing footer has text-align: center, which might be enough.
		   If its content still looks off, we can wrap its inner content
		   with <div class="content-wrapper"> too. Let's see first. #}
		{% include "components/footer.njk" %}

		<script src='https://storage.ko-fi.com/cdn/scripts/overlay-widget.js'></script>
		<script>
		// 1. Handle Dark Mode Logic
		const toggle = document.querySelector('#dark-mode-toggle');
		const body = document.body;
		const savedTheme = localStorage.getItem('theme');

		if (savedTheme === 'dark') {
			body.classList.add('dark-mode');
			toggle.checked = true;
		}

		// Function to determine current primary color for Ko-fi
		function updateKofiColor() {
			const themeVar = body.classList.contains('serious-theme') ? '--primary-serious' : 
							body.classList.contains('lecture-theme') ? '--primary-lecture' : '--primary';
			const newColor = window.getComputedStyle(body).getPropertyValue(themeVar).trim();
			const kofiBtn = document.querySelector('.floating-chat-kofi-status');
			if (kofiBtn) kofiBtn.style.backgroundColor = newColor || '#2e6319';
		}

		toggle.addEventListener('change', () => {
			if (toggle.checked) {
			body.classList.add('dark-mode');
			localStorage.setItem('theme', 'dark');
			} else {
			body.classList.remove('dark-mode');
			localStorage.setItem('theme', 'light');
			}
			
			// Wait for CSS variable shift, then update button
			setTimeout(updateKofiColor, 50);
		});

		// 2. Initialize Ko-fi Button
		{% set theme_primary_var = "--primary" %}
		{% if serious or '/tags/serious/' in page.url %}
			{% set theme_primary_var = "--primary-serious" %}
		{% elif lecture or '/tags/lecture/' in page.url %}
			{% set theme_primary_var = "--primary-lecture" %}
		{% endif %}

		const initialColor = window.getComputedStyle(document.body).getPropertyValue('{{ theme_primary_var }}').trim();

		kofiWidgetOverlay.draw('creativealloy', {
			'type': 'floating-chat',
			'floating-chat.donateButton.text': 'Tip Me',
			'floating-chat.donateButton.background-color': initialColor || '#2e6319', 
			'floating-chat.donateButton.text-color': '#fff'
		});

		// Ensure button color is correct on initial load if dark mode is active
		if (savedTheme === 'dark') {
			setTimeout(updateKofiColor, 50);
		}
		</script>

	</body>

</html>
<!doctype html>
<html {% if section %} data-current="{{ section }}"{% endif %} lang="en">

	{% include "components/head.njk" %}

	<body class="{% if serious or '/tags/serious/' in page.url %}serious-theme{% elif lecture or '/tags/lecture/' in page.url %}lecture-theme{% endif %}">

		<header>
			{# Wrap header content to center it #}
			<div class="content-wrapper"> 
				<em>
					<a href="{{ '/' | url }}">{{ metadata.title }}</a>
				</em>
				{% include "components/nav.njk" %}

				{# Include the ad unit here #}
        		{% include "components/a-ads.njk" %}
			</div>
		</header>

		<main>
			{{ layoutContent | safe }}
		</main>

		{# The existing footer has text-align: center, which might be enough.
		   If its content still looks off, we can wrap its inner content
		   with <div class="content-wrapper"> too. Let's see first. #}
		{% include "components/footer.njk" %}

		<script src='https://storage.ko-fi.com/cdn/scripts/overlay-widget.js'></script>
		<script>
		// 1. Determine which CSS variable name to use based on the active theme logic
		{% set theme_primary_var = "--primary" %}
		{% if serious or '/tags/serious/' in page.url %}
			{% set theme_primary_var = "--primary-serious" %}
		{% elif lecture or '/tags/lecture/' in page.url %}
			{% set theme_primary_var = "--primary-lecture" %}
		{% endif %}

		// 2. Extract the color value from the body computed styles
		// This ensures we get the actual color without hardcoding hex codes here.
		const activeThemeColor = window.getComputedStyle(document.body).getPropertyValue('{{ theme_primary_var }}').trim();

		kofiWidgetOverlay.draw('creativealloy', {
			'type': 'floating-chat',
			'floating-chat.donateButton.text': 'Tip Me',
			'floating-chat.donateButton.background-color': activeThemeColor || '#2e6319', 
			'floating-chat.donateButton.text-color': '#fff'
		});
		</script>

	</body>

</html>